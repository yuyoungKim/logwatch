# ============================================================
# logwatch — environment variable reference
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=logwatch
POSTGRES_USER=logwatch
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_PORT=5432

# Full DSN used by the consumer service.
# Format: postgres://<user>:<password>@<host>:<port>/<db>?sslmode=disable
DATABASE_URL=postgres://logwatch:changeme_postgres@localhost:5432/logwatch?sslmode=disable

# --- Redis ---
REDIS_PASSWORD=changeme_redis
REDIS_PORT=6379

# Full Redis URL used by future services.
REDIS_URL=redis://:changeme_redis@localhost:6379/0

# --- Ingestion / Consumer ---
# How many log events to emit per second across all services.
LOG_RATE=10

# Probability [0.0–1.0] that any given log event is an anomaly.
ANOMALY_RATE=0.05

# Number of log rows to accumulate before flushing to the database.
BATCH_SIZE=50

# How often (in milliseconds) to force-flush even if the batch isn't full.
FLUSH_INTERVAL_MS=2000

# --- ML service (Phase 2) ---
ML_SERVICE_URL=http://localhost:8000
